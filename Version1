:root {
  --bg: #f5f5f7;
  --surface: #ffffff;
  --text-primary: #1d1d1f;
  --text-secondary: #6e6e73;
  --text-en: #8e8e93;
  --accent: #0071e3;
  --accent-light: #e8f1fb;
  --border: #d2d2d7;
  --gold: #c8a96e;
}

body {
  background: var(--bg);
  font-family: 'Noto Serif TC', serif;
  color: var(--text-primary);
  min-height: 100vh;
}

/* ── Hero ── */
.hero {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 90px 24px 70px;
  text-align: center;
  background: linear-gradient(160deg, #000 0%, #1a1a2e 55%, #0a0a0a 100%);
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 50% at 50% 0%, rgba(0,113,227,0.25) 0%, transparent 70%),
    radial-gradient(ellipse 40% 40% at 80% 80%, rgba(200,169,110,0.12) 0%, transparent 60%);
  pointer-events: none;
}

.apple-logo {
  font-size: 50px;
  margin-bottom: 22px;
}

.hero-eyebrow {
  font-family: 'Lato', sans-serif;
  font-weight: 300;
  font-size: 12px;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 16px;
}

.hero h1 {
  font-family: 'DM Serif Display', serif;
  font-size: clamp(32px, 5.5vw, 60px);
  font-weight: 400;
  line-height: 1.15;
  color: #f5f5f7;
  margin-bottom: 10px;
}

.hero h1 em {
  font-style: italic;
  color: var(--gold);
}

.hero-en {
  font-family: 'DM Serif Display', serif;
  font-style: italic;
  font-size: clamp(16px, 2.5vw, 24px);
  color: rgba(255,255,255,0.35);
  margin-top: 6px;
}

/* ── Divider ── */
.divider-wrap {
  background: var(--bg);
  padding: 44px 0 0;
  display: flex;
  justify-content: center;
}

.divider {
  width: 56px;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
}

/* ── Cards ── */
.reasons {
  max-width: 860px;
  margin: 0 auto;
  padding: 60px 24px 80px;
  display: flex;
  flex-direction: column;
  gap: 28px;
}

.reason-card {
  background: var(--surface);
  border-radius: 20px;
  padding: 48px 52px;
  box-shadow: 0 2px 24px rgba(0,0,0,0.07);
  position: relative;
  overflow: hidden;
}

.reason-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 4px;
  height: 100%;
  background: linear-gradient(180deg, var(--accent), var(--gold));
  border-radius: 4px 0 0 4px;
}

.reason-number {
  font-family: 'DM Serif Display', serif;
  font-size: 68px;
  font-style: italic;
  color: var(--accent-light);
  line-height: 1;
  position: absolute;
  top: 22px; right: 36px;
  user-select: none;
  letter-spacing: -2px;
}

.reason-tag {
  display: inline-block;
  font-family: 'Lato', sans-serif;
  font-size: 11px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--accent);
  background: var(--accent-light);
  padding: 5px 14px;
  border-radius: 20px;
  margin-bottom: 18px;
}

.reason-card h2 {
  font-family: 'DM Serif Display', serif;
  font-size: 24px;
  font-weight: 400;
  margin-bottom: 16px;
  color: var(--text-primary);
}

.zh {
  font-size: 15.5px;
  line-height: 1.9;
  color: var(--text-secondary);
  font-weight: 300;
  margin-bottom: 20px;
}

.en-block {
  border-top: 1px solid var(--border);
  padding-top: 20px;
  margin-top: 4px;
}

.en-label {
  font-family: 'Lato', sans-serif;
  font-size: 10px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--border);
  margin-bottom: 10px;
}

.en {
  font-family: 'Lato', sans-serif;
  font-size: 14.5px;
  line-height: 1.85;
  color: var(--text-en);
  font-weight: 300;
}

.emoji-accent { font-size: 1.05em; vertical-align: middle; }

/* ── Footer ── */
footer {
  background: #000;
  padding: 36px 24px;
  text-align: center;
}

footer p {
  font-family: 'Lato', sans-serif;
  font-size: 12px;
  color: rgba(255,255,255,0.28);
  letter-spacing: 0.5px;
}

@media (max-width: 600px) {
  .reason-card { padding: 36px 28px; }
  .reason-number { font-size: 50px; right: 18px; top: 16px; }
}
